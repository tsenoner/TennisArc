{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "git": { "deploymentEnabled": { "data": false } },
  "rewrites": [
    {
      "source": "/data/:tour(atp|wta)-:year(\\d{4})-:slam([a-z0-9-]+).json",
      "destination": "/data/slams/:year/:tour-:slam.json"
    },
    { "source": "/(.*)", "destination": "/" }
  ],
  "headers": [
    { "source": "/data/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] }
  ]
}
