{
  "name": "tennisarc",
  "version": "0.1.0",
  "description": "Live radial-bracket PWA for Grand Slam tennis (ATP + WTA)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "TZ=UTC vitest run",
    "test:watch": "TZ=UTC vitest",
    "typecheck": "tsc --noEmit",
    "generate-pwa-assets": "pwa-assets-generator",
    "ingest": "tsx ingest/index.ts",
    "reindex": "tsx ingest/reindex.ts",
    "backfill-durations": "tsx ingest/backfill-durations.ts",
    "backfill-finals": "tsx ingest/backfill-finals.ts",
    "backfill-seeds": "tsx ingest/backfill-seeds.ts",
    "backfill-elo": "tsx ingest/backfill-elo.ts",
    "elo:scatter": "tsx ingest/elo-reverse/parse-boards.ts && tsx ingest/elo-reverse/parse-yelo.ts && tsx ingest/elo-reverse/yelo-fit.ts ATP --scatter && tsx ingest/elo-reverse/yelo-fit.ts WTA --scatter && tsx ingest/elo-reverse/dashboard-data.ts && tsx ingest/points/engine.ts --emit && tsx ingest/elo-reverse/serve.ts",
    "elo:scatter-legacy": "tsx ingest/elo-reverse/scatter.ts && open ingest/elo-reverse/elo-scatter.html",
    "elo:check-points": "tsx ingest/points/engine.ts --check"
  },
  "dependencies": {
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "flag-icons": "^7.5.0",
    "idb-keyval": "^6.2.5"
  },
  "devDependencies": {
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.8",
    "@types/d3-shape": "^3.1.6",
    "@types/node": "^25.9.2",
    "@vite-pwa/assets-generator": "^0.2.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.5",
    "vitest": "^2.1.0"
  }
}
