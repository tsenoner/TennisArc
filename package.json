{
  "name": "tennisarc",
  "version": "0.1.0",
  "description": "Live radial-bracket PWA for Grand Slam tennis (ATP + WTA)",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
